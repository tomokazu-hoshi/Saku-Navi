---
layout: null
---
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  <url>
    <loc>{{ site.url }}{{ site.baseurl }}/</loc>
    <priority>1.0</priority>
  </url>

  <url><loc>{{ site.url }}{{ site.baseurl }}/index-a-column.html</loc><priority>0.8</priority></url>
  <url><loc>{{ site.url }}{{ site.baseurl }}/months-menu.html</loc><priority>0.8</priority></url>
  <url><loc>{{ site.url }}{{ site.baseurl }}/seasons-menu.html</loc><priority>0.8</priority></url>
  <url><loc>{{ site.url }}{{ site.baseurl }}/colors-menu.html</loc><priority>0.8</priority></url>
  <url><loc>{{ site.url }}{{ site.baseurl }}/types-menu.html</loc><priority>0.8</priority></url>
  <url><loc>{{ site.url }}{{ site.baseurl }}/envs-menu.html</loc><priority>0.8</priority></url>
  <url><loc>{{ site.url }}{{ site.baseurl }}/purposes-menu.html</loc><priority>0.8</priority></url>
  <url><loc>{{ site.url }}{{ site.baseurl }}/families-menu.html</loc><priority>0.8</priority></url>
  <url><loc>{{ site.url }}{{ site.baseurl }}/meanings-menu.html</loc><priority>0.8</priority></url>
  <url><loc>{{ site.url }}{{ site.baseurl }}/methods-menu.html</loc><priority>0.8</priority></url>

  {% assign rows = "a,ka,sa,ta,na,ha,ma,ya,ra,wa" | split: "," %}
  {% for row in rows %}
  <url>
    <loc>{{ site.url }}{{ site.baseurl }}/{{ row }}-row.html</loc>
    <priority>0.7</priority>
  </url>
  {% endfor %}

  {% for post in site.posts %}
  <url>
    <loc>{{ site.url }}{{ post.url }}</loc>
    <lastmod>{{ post.date | date_to_xmlschema }}</lastmod>
    <priority>0.5</priority>
  </url>
  {% endfor %}
</urlset>
