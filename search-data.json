---
layout: none
---
[
  {% for post in site.posts %}
    {
      "title": {{ post.title | default: "無題" | jsonify }},
      "url": {{ post.url | relative_url | jsonify }},
      "tags": [
        {% assign all_tags = "" | split: "," %}
        {% if post.categories %}{% assign all_tags = all_tags | concat: post.categories %}{% endif %}
        {% if post.tags %}{% assign all_tags = all_tags | concat: post.tags %}{% endif %}
        {% assign unique_tags = all_tags | uniq %}
        {% for tag in unique_tags %}
          {{ tag | jsonify }}{% unless forloop.last %},{% endunless %}
        {% endfor %}
      ]
    }{% unless forloop.last %},{% endunless %}
  {% endfor %}
]
